# etcd Configuration
ETCD_SERVER=your_etcd_server_ip
ETCD_PORT=2379
ETCD_PREFIX=/discovery/

# AWX Configuration
AWX_SERVER=your_awx_server_ip
AWX_INVENTORY_NAME=central inventory

# AWX Authentication - Choose ONE option:

# Option 1: Personal Access Token (recommended)
# AWX_TOKEN=your_personal_access_token

# Option 2: OAuth2 Resource Owner Password-Based
AWX_CLIENT_ID=your_client_id
AWX_CLIENT_SECRET=your_client_secret
AWX_USERNAME=your_username
AWX_PASSWORD=your_password

# Option 3: Basic Username/Password (without OAuth)
# AWX_USERNAME=your_username
# AWX_PASSWORD=your_password

# GitHub Configuration
# GHE token (github.cds.internal.unity3d.com) - for vivox-ops-docker repo
GITHUB_TOKEN=your_ghe_token
# Public GitHub token (github.com) - for vivox-ops-ansible repo
TF_GITHUB_TOKEN=your_github_com_token

# Slack Integration (optional - for slack_bot.py and --slack-alert)
# See docs/SLACK_SETUP.md for detailed setup instructions
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_CHANNEL_ID=C0123456789

# Ops notification channel for restart alerts
OPS_NOTIFICATION_CHANNEL_ID=C01LM1U6YG7
